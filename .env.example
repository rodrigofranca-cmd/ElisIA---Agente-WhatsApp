# ==============================================
# CONFIGURAÇÕES DO GOOGLE GEMINI
# ==============================================
# Sua chave de API do Google AI Studio
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_api_gemini_aqui

# ==============================================
# CONFIGURAÇÕES DO WHATSAPP CLOUD API
# ==============================================
# Token de acesso permanente do WhatsApp Business API
# Obtido no Meta Business Suite > WhatsApp > Configurações da API
WHATSAPP_TOKEN=seu_token_whatsapp_aqui

# ID do número de telefone do WhatsApp Business
# Encontrado no Meta Business Suite > WhatsApp > Números de telefone
WHATSAPP_PHONE_ID=seu_phone_id_aqui

# Token de verificação para configurar o webhook
# Você define este valor ao configurar o webhook no Meta Business Suite
VERIFY_TOKEN=seu_token_verificacao_personalizado

# ==============================================
# CONFIGURAÇÕES OPCIONAIS
# ==============================================
# Nome da loja para personalizar as respostas do bot
STORE_NAME=ElisIA Store
